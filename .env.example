# =============================================================================
# Angel One SmartAPI — copy to `.env` and fill every required value.
# Never commit `.env`. Keep execution server-side only.
# Docs: https://smartapi.angelone.in
# =============================================================================

# -----------------------------------------------------------------------------
# BROKER AUTH (required)
# -----------------------------------------------------------------------------
# API key from SmartAPI “My Apps” (this is X-PrivateKey on every request).
ANGEL_API_KEY=

# Your Angel client id / login id.
ANGEL_CLIENT_CODE=

# MPIN / PIN used as `password` in loginByPassword.
ANGEL_PIN=

# TOTP — pick ONE of these flows:
#
#   (A) Manual / safest — leave BOTH blank, enter the code in the dashboard UI
#       on every connect. Good for casual / supervised usage.
#
#   (B) FULL AUTOMATION — paste the base32 secret you get from Angel after
#       enabling TOTP at https://smartapi.angelone.in/enable-totp into
#       ANGEL_TOTP_SECRET below. The backend will:
#         - auto-connect on startup (no UI typing),
#         - auto re-login after broker session expiry (daily / midnight),
#         - if BOT_AUTOSTART=true, also start the trading loop on startup.
#       This stores a long-lived secret on disk; treat it like a password and
#       keep .env out of source control.
#
# ANGEL_TOTP is only for one-shot CLI runs ("here is the live 6-digit code").
ANGEL_TOTP=
ANGEL_TOTP_SECRET=

# -----------------------------------------------------------------------------
# DASHBOARD (runtime TOTP + connect + start/stop bot)
# -----------------------------------------------------------------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=9812
# Optional shared secret that protects the dashboard API from other processes
# on the same host. If set, every /api request must send X-Dashboard-Token.
# This is NOT your TOTP — leave blank unless you understand it.
DASHBOARD_TOKEN=
# Comma-separated origins allowed to call /api from the React dev server.
DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# AUTO-TRADER (server-side bot)
# -----------------------------------------------------------------------------
# IMPORTANT: leave false until you have validated behavior. When false the bot
# only logs intended trades (dry-run); no orders are sent to Angel One.
TRADING_ENABLED=false
BOT_LOOP_INTERVAL_S=5.0
BOT_MAX_CONCURRENT_POSITIONS=3
# Cap on the % of available broker cash the bot may deploy per cycle.
# 100 = use every rupee (recommended for options BUYING — you pay the full
# premium upfront, no margin-call risk). Lower it (e.g. 80) only if you
# want to keep a passive cash buffer.
BOT_USE_CAPITAL_PCT=100
# Minimum scanner score to consider acting on (0 = consider any non-flat hit).
BOT_MIN_SIGNAL_STRENGTH=0.0
# Default product / variety for live placement (broker enums).
BOT_DEFAULT_PRODUCT=INTRADAY
BOT_DEFAULT_VARIETY=NORMAL

# When ANGEL_TOTP_SECRET is set:
#   AUTO_CONNECT_ON_STARTUP=true → backend logs in to Angel as soon as it boots
#   BOT_AUTOSTART=true           → trading loop starts immediately after login
#   AUTO_RELOGIN_INTERVAL_S      → how often to verify the broker session and
#                                   trigger a fresh login if it has expired
AUTO_CONNECT_ON_STARTUP=true
BOT_AUTOSTART=false
AUTO_RELOGIN_INTERVAL_S=900

# -----------------------------------------------------------------------------
# SCANNER WATCHLIST
# Provide instruments the scanner / bot will track. Each entry needs the
# Angel One symboltoken (find it in your instrument master CSV).
# Schema: { "<EXCHANGE>": [ { "name": "...", "token": "...", "kind": "INDEX|EQUITY|COMMODITY", "lot_size": <int> } ] }
# -----------------------------------------------------------------------------
SCANNER_WATCHLIST_JSON={"NSE":[{"name":"NIFTY","token":"99926000","kind":"INDEX","lot_size":50},{"name":"BANKNIFTY","token":"99926009","kind":"INDEX","lot_size":15},{"name":"FINNIFTY","token":"99926037","kind":"INDEX","lot_size":40}]}

# -----------------------------------------------------------------------------
# CLIENT IDENTITY HEADERS (required by broker on every call)
# Use real values in production; static IP VPS is typical for 24/7.
# -----------------------------------------------------------------------------
ANGEL_CLIENT_LOCAL_IP=127.0.0.1
ANGEL_CLIENT_PUBLIC_IP=127.0.0.1
ANGEL_MAC_ADDRESS=00:00:00:00:00:00

# REST base (production default).
ANGEL_BASE_URL=https://apiconnect.angelone.in

# -----------------------------------------------------------------------------
# MARKET DATA — REST poll (Phase 1)
# -----------------------------------------------------------------------------
# Seconds between getLtpData polls when using `poll-ltp` / pipeline.
LTP_POLL_INTERVAL_S=7.5

# JSON mapping of exchange segment -> list of symbol tokens as strings.
# Keys must match getLtpData: "NSE", "NFO", "BSE", "MCX", "CDS", etc.
# Example NIFTY spot + one equity: {"NSE":["99926000","2885"]}
# Find tokens in Angel instrument master CSV (`token` column).
LTP_EXCHANGE_TOKENS_JSON={"NSE":["99926000"]}

# -----------------------------------------------------------------------------
# MARKET DATA — WebSocket (Phase 2, Smart Stream v2)
# -----------------------------------------------------------------------------
# Comma-separated subscriptions: `exchangeType:token,token|exchangeType:token`
# exchangeType: 1=NSE_CM, 2=NSE_FO, 3=BSE_CM, 4=BSE_FO, 5=MCX_FO, 7=NCX_FO, 13=CDE_FO
# Example: NIFTY index (verify token in master) + two NFO tokens:
# WS_SUBSCRIPTIONS=1:99926000|2:12345,67890
WS_SUBSCRIPTIONS=

# 1=LTP, 2=QUOTE, 3=SNAP_QUOTE, 4=DEPTH (see Angel docs).
WS_FEED_MODE=1

# -----------------------------------------------------------------------------
# INSTRUMENT MASTER + DYNAMIC UNIVERSE
# -----------------------------------------------------------------------------
# Where to keep the local copy of Angel's full scrip master. The bot
# auto-downloads it from INSTRUMENT_MASTER_URL on startup if missing or stale.
# JSON is preferred (Angel's official format); a CSV path also works.
INSTRUMENT_MASTER_PATH=./data/angel_scrip_master.json
INSTRUMENT_MASTER_URL=https://margincalculator.angelbroking.com/OpenAPI_File/files/OpenAPIScripMaster.json
INSTRUMENT_MASTER_AUTO_DOWNLOAD=true
# Re-download if the local cache is older than this many hours (Angel
# publishes a fresh file every trading day).
INSTRUMENT_MASTER_MAX_AGE_HOURS=20
# Legacy: only respected if INSTRUMENT_MASTER_PATH is unset.
INSTRUMENT_MASTER_CSV=

# Dynamic watchlist spec — when set, OVERRIDES SCANNER_WATCHLIST_JSON.
# Tokens, lot sizes and ATM strikes are resolved from the instrument master
# at startup and refreshed every ATM_REFRESH_INTERVAL_S seconds (so the ATM
# strike tracks the underlying as it moves).
#
# Schema:
#   indices       list of underlyings — also rendered as INDEX cards on UI
#   stocks        list of NSE cash equities
#   commodities   list of MCX commodity underlyings (nearest future is picked)
#   atm_for       list of underlyings whose CE/PE chain to load
#   atm_offsets   strikes around ATM, e.g. [-2,-1,0,1,2] = ITM-2 .. OTM+2
#   atm_expiries  how many of the next expiries to include per underlying
#
# Default below = every options-eligible Indian index Angel exposes:
#   NSE F&O (NFO):  NIFTY, BANKNIFTY, FINNIFTY, MIDCPNIFTY, NIFTYNXT50
#   BSE F&O (BFO):  SENSEX, BANKEX
# 5 strikes per side × 2 next expiries = 20 option entries per underlying.
# Leave UNIVERSE_SPEC_JSON empty to use the in-code default (recommended).
UNIVERSE_SPEC_JSON=
# How often (seconds) to re-resolve ATM option contracts while the bot runs.
ATM_REFRESH_INTERVAL_S=120

# -----------------------------------------------------------------------------
# RISK & CAPITAL (used by RiskEngine)
# -----------------------------------------------------------------------------
# These are the BOT'S OWN trading rules — independent of the broker. The
# broker only tells us your available cash; it does not enforce per-trade
# risk, daily loss caps, or trade-frequency limits. The bot does.
#
# RISK_CAPITAL_RUPEES is the capital BASE used to compute:
#   - per-trade risk in rupees   = base × (RISK_PER_TRADE_PCT / 100)
#   - daily loss cap in rupees   = base × (RISK_MAX_DAILY_LOSS_PCT / 100)
#
# Set to 0 (recommended) to AUTO-USE your live broker available cash from
# Angel's RMS endpoint each loop. Set to a fixed number (e.g. 100000) only
# if you want sizing to ignore your real cash and use a synthetic budget.
RISK_CAPITAL_RUPEES=0
RISK_PER_TRADE_PCT=1.0
RISK_MAX_DAILY_LOSS_PCT=2.5
RISK_MAX_TRADES_PER_DAY=12
RISK_ONE_POSITION_AT_A_TIME=false
# Rolling 60-minute trade cap. Hard guard so a fast strategy can't blow
# through the day in one bad hour. 0 disables it.
RISK_MAX_TRADES_PER_HOUR=3
# After a losing close (paper or live), refuse new entries for this many
# minutes to prevent revenge trading. 0 disables.
RISK_LOSS_COOLDOWN_MINUTES=10

# -----------------------------------------------------------------------------
# STATE & ORDER RECONCILIATION
# -----------------------------------------------------------------------------
# SQLite path for orders, positions, daily stats.
STATE_SQLITE_PATH=./data/angel_bot_state.sqlite3

# How often to pull order book and update lifecycle (seconds).
ORDER_RECONCILE_INTERVAL_S=15

# -----------------------------------------------------------------------------
# BRAIN — 5-MINUTE PRIMARY pipeline
# -----------------------------------------------------------------------------
# 5m is the primary decision timeframe; 1m drives the entry trigger; 15m is
# bias-only (we only require it not to be against the trade). The score is
# a weighted sum of three 0..1 factors that must sum to ~1.0 (volume_w stays
# 0 until WebSocket QUOTE is wired — REST LTP doesn't return volume).
SCORE_W_VOLATILITY=0.25     # session-range based "movement potential"
SCORE_W_MOMENTUM=0.45       # 5m close-to-close slope (PRIMARY)
SCORE_W_BREAKOUT=0.30       # 5m STRUCTURE: max(breakout, pullback, continuation)
SCORE_W_VOLUME=0.00         # placeholder

# Primary timeframe label (informational; the brain code is hard-wired to 5m)
STRATEGY_PRIMARY_TIMEFRAME=5m

# Universe filters — very relaxed; the LLM classifier is the quality gate.
STRATEGY_MIN_VOLATILITY_PCT=0.10    # intraday range / price (in percent)
STRATEGY_MAX_CHOP_SCORE=0.80        # 0..1, higher = choppier (only the *very* sideways stuff is rejected)

# Entry timing thresholds — applied per-pattern.
# Lowered ~3x so a 100-200pt NIFTY push (≈ 0.04-0.08%) qualifies.
STRATEGY_MIN_5M_TREND_SLOPE=0.0003       # PRIMARY trend gate (0.03%)
STRATEGY_MIN_15M_TREND_SLOPE=0.0002      # 15m bias only — very loose
STRATEGY_MIN_BREAKOUT_CLEARANCE=0.0003   # strict 5m swing-cross threshold (0.03%)
STRATEGY_NEAR_BREAKOUT_CLEARANCE=0.0030  # also allow "near breakout" entries (0.30% band)
STRATEGY_MAX_LATE_ENTRY_PCT=0.0200       # allow up to 2% late entry (exits cap the loss)
STRATEGY_MIN_ABOVE_TWAP_PCT=0.0          # CALL needs price >= twap*(1+x)

# Pullback (uptrend retracement) thresholds
STRATEGY_PULLBACK_MIN_UPTREND_BARS=2        # need this many green 5m bars first
STRATEGY_PULLBACK_MAX_RETRACEMENT_PCT=0.020 # max retracement from swing high (2%)

# Continuation (consolidation after breakout) thresholds
STRATEGY_CONTINUATION_CONSOLIDATION_BARS=2  # how many 5m bars must be inside
STRATEGY_CONTINUATION_MAX_RANGE_PCT=0.006   # max range of consolidation (0.6%)

# SCALP / MOMENTUM — fastest path. Just 3 checks (5m up + 1m close + 15m
# not against). Targets 100-200pt NIFTY-style pushes that don't have full
# breakout structure yet. Survival relies on tight EXIT rules below, not
# rigid entries.
STRATEGY_SCALP_MIN_5M_SLOPE=0.0003

# Minimum brain score (0..1) to even surface as a candidate. Lowered to
# 0.30 → brain produces lots of candidates → LLM_DECISION_THRESHOLD picks
# the cleanest. Brain = scout, LLM = sniper.
STRATEGY_MIN_SCORE=0.30

# Reject candidates whose 1-lot notional falls outside this rupee range.
# 0 disables that bound. Use to keep the bot inside an instrument-cost band
# you are comfortable with, regardless of total available cash.
STRATEGY_MIN_TRADE_VALUE=0
STRATEGY_MAX_TRADE_VALUE=0

# -----------------------------------------------------------------------------
# DRY-RUN / PAPER TRADING
# When TRADING_ENABLED=false the bot still runs the full pipeline but, instead
# of sending an order, OPENS a paper position. Mark-to-market and auto-exits
# (stop / target / timeout) are computed locally and shown on the dashboard.
# Live and dry-run P&L are tracked in separate ledgers — switching modes does
# not corrupt either history.
# -----------------------------------------------------------------------------
# Sizing capital used in dry-run. 0 = use real broker available cash (so the
# sim mirrors what live would do today). > 0 = simulate "what trades would the
# bot take with ₹X?" without touching the live account. The dashboard exposes
# a slider/input that overrides this in real time.
DRYRUN_CAPITAL_OVERRIDE=0
# Tight scalp-friendly exits. Each LOSS is bounded at ~0.6% of premium paid;
# winners exit at ~1.2% (2:1 reward:risk). Max hold cuts dead trades fast
# so capital cycles into the next setup.
PAPER_STOP_LOSS_PCT=0.006
PAPER_TAKE_PROFIT_PCT=0.012
PAPER_MAX_HOLD_MINUTES=25
PAPER_MAX_OPEN_POSITIONS=5

# -----------------------------------------------------------------------------
# RATE LIMITS — client-side guard for Angel One published quotas
# https://smartapi.angelone.in/docs/RateLimit
# Keep enabled. Disable only in offline tests where the broker is mocked.
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
# Run at this fraction of the documented per-window cap (0..1). Default 0.9
# leaves ~10% headroom for clock skew, in-flight retries, and the watchdog.
RATE_LIMIT_SAFETY_FACTOR=0.9

# -----------------------------------------------------------------------------
# OPTIONAL — LLM TRADE CLASSIFIER (5m primary pipeline)
# -----------------------------------------------------------------------------
# When OPENAI_API_KEY is set AND LLM_FILTER_ENABLED=true, every candidate the
# rule-based brain produces is sent to OpenAI as a *classifier* AFTER all
# cheap gates pass (signal exists, market open, instrument resolved, funds
# OK, risk OK). The LLM returns a strict JSON object:
#     { decision: "TAKE"|"SKIP", confidence: 0..1,
#       type: "breakout"|"pullback"|"continuation"|"other",
#       reason: "<=120 chars" }
# The runtime then requires decision == TAKE AND confidence >= the threshold
# below. The LLM cannot create new trades — it can only allow or skip ones
# the brain already approved. The outgoing payload is sanitized: no API
# keys, no JWTs, no broker tokens, no client code.
# ~1 OpenAI request per actual trade attempt (not per scan).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_FILTER_ENABLED=true
# If OpenAI is unreachable (timeout / 5xx / non-JSON):
#   true  → skip the trade (safe, default)
#   false → fall through with confidence=0.5 — usually still blocked by
#           the threshold below unless you also lower it
LLM_FILTER_FAIL_CLOSED=true
LLM_FILTER_TIMEOUT_S=8.0
# Minimum classifier confidence (0..1) required to actually place the
# trade. 0.65 = "moderately confident". Raise to 0.75 for fewer/better
# trades; lower to 0.55 for more frequent activity.
LLM_DECISION_THRESHOLD=0.65
# How many top-scoring brain candidates per loop the classifier may grade.
# Each one gets at most 1 OpenAI call. The bot stops as soon as
# BOT_MAX_CONCURRENT_POSITIONS is reached this loop.
LLM_TOP_N_CANDIDATES=3

# -----------------------------------------------------------------------------
# OPTIONAL — RUNTIME / OBSERVABILITY
# -----------------------------------------------------------------------------
# json | console
LOG_FORMAT=console
